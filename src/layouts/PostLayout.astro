---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, ogImage } = post.data;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

function readingTime(content: string): string {
  const wpm = 200;
  const words = content.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / wpm));
  return `${mins} min read`;
}

const { body } = post;
const readTime = readingTime(body);
const canonicalURL = new URL(`/blog/${post.slug}/`, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": "Niall Walsh",
    "url": Astro.site
  },
  "publisher": {
    "@type": "Person",
    "name": "Niall Walsh",
    "url": Astro.site
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  },
  ...(tags.length > 0 && { "keywords": tags.join(", ") }),
  ...(ogImage && { "image": new URL(ogImage, Astro.site).toString() })
};
---

<BaseLayout title={title} description={description} type="article" ogImage={ogImage}>
  <!-- Article-specific Open Graph and schema -->
  <meta property="article:published_time" content={pubDate.toISOString()} slot="head" />
  {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} slot="head" />}
  <meta property="article:author" content="Niall Walsh" slot="head" />
  {tags.map(tag => <meta property="article:tag" content={tag} slot="head" />)}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <div class="article-page">
    <a href="/" class="back-link" aria-label="Back to all posts">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      All posts
    </a>

    <article>
      <header class="article-header">
        {
          tags.length > 0 && (
            <div class="article-header__tags">
              <ul class="tags" role="list" aria-label="Post tags">
                {tags.map((tag) => (
                  <li>
                    <a href={`/tags/${tag}/`} class="tag">
                      {tag}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <h1 class="article-title">{title}</h1>

        {description && <p class="article-desc">{description}</p>}

        <div class="article-meta">
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
          <span class="article-meta__sep" aria-hidden="true">·</span>
          <span>{readTime}</span>
          {
            updatedDate && (
              <>
                <span class="article-meta__sep" aria-hidden="true">·</span>
                <span>
                  Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
                </span>
              </>
            )
          }
        </div>
      </header>

      {ogImage && (
        <div class="article-hero-image">
          <img src={ogImage} alt="" role="presentation" />
        </div>
      )}

      <div class="article-prose">
        <div class="prose">
          <slot />
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
