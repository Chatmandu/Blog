---
const navLinks = [
  { href: '/',       label: 'Writing' },
  { href: '/about/', label: 'About'   },
  { href: '/rss.xml',label: 'RSS'     },
];

const currentPath = Astro.url.pathname;
---

<header class="site-sidebar" role="banner">

  <!-- Small decorative circle — visual anchor, top -->
  <span class="site-sidebar__dot" aria-hidden="true"></span>

  <!-- Rotated site name — home link, centred on sidebar -->
  <a href="/" class="site-logo" aria-label="Niall Walsh — home">
    Niall&nbsp;Walsh
  </a>

  <!-- Nav links — rotated on desktop, inline on mobile -->
  <nav class="site-sidebar__nav" aria-label="Site navigation">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class="site-nav__link"
        aria-current={
          currentPath === href ||
          (href !== '/' && currentPath.startsWith(href))
            ? 'page'
            : undefined
        }
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Theme toggle — bottom of sidebar -->
  <button
    id="theme-toggle"
    class="theme-toggle"
    aria-label="Toggle colour theme"
    type="button"
  >
    <!-- Sun icon (shown in dark mode) -->
    <svg
      id="icon-sun"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      style="display:none"
    >
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>

    <!-- Moon icon (shown in light mode) -->
    <svg
      id="icon-moon"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>

</header>
